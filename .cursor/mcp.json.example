{
  "mcpServers": {
    "zendesk": {
      "command": "python3",
      "args": [
        "scripts/zendesk_mcp_server.py",
        "--subdomain", "datadog",
        "--email", "your.email@datadoghq.com",
        "--token", "YOUR_ZENDESK_API_TOKEN"
      ]
    },
    "atlassian": {
      "command": "uvx",
      "args": [
        "mcp-atlassian",
        "--jira-url", "https://datadoghq.atlassian.net",
        "--jira-username", "your.email@datadoghq.com",
        "--jira-token", "YOUR_ATLASSIAN_API_TOKEN",
        "--confluence-url", "https://datadoghq.atlassian.net/wiki",
        "--confluence-username", "your.email@datadoghq.com",
        "--confluence-token", "YOUR_ATLASSIAN_API_TOKEN",
        "--read-only"
      ]
    },
    "github": {
      "command": "uvx",
      "args": ["mcp-github"],
      "env": {
        "GITHUB_TOKEN": "YOUR_GITHUB_PAT"
      }
    }
  }
}
